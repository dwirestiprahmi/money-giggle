# Copy this file to .env and fill in your values
# Never commit .env to version control

# Database
DB_URL=jdbc:postgresql://localhost:5432/moneymanager
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_256bit_hex_secret
JWT_EXPIRATION=86400000        # 24h in ms
JWT_REFRESH_EXPIRATION=604800000  # 7d in ms

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Tesseract OCR data path (Linux default; override if needed)
TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata

# Currency API (optional — free tier, no key needed for exchangerate-api.com)
# CURRENCY_API_URL=https://api.exchangerate-api.com/v4/latest
